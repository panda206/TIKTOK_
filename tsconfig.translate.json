{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": false,
    "esModuleInterop": true,
    "types": ["node"],

    "rootDir": "./src/translate",
    "outDir": "./dist/translate",

    "skipLibCheck": true,
    // 💡 必须加上这一行：强迫把每个文件当做独立模块，阻断全局命名空间污染
    "isolatedModules": true
  },
  "include": ["src/translate/**/*"]
}